# ============================================================
# 校园预约系统 — Docker 部署环境变量模板
# 复制为 .env 后修改
# ============================================================

# ---- 端口 ----
MYSQL_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=18080
FRONTEND_PORT=80

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=your_mysql_password

# ---- Redis（留空则不设密码） ----
REDIS_PASSWORD=

# ---- SMTP 邮件 ----
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=your_email@163.com
SMTP_PASSWORD=your_smtp_auth_code

# ---- JWT（生产环境用 openssl rand -base64 64 生成） ----
JWT_SECRET=your_jwt_secret_base64
JWT_EXPIRATION=86400000

# ---- 文件上传 ----
FILE_UPLOAD_PATH=./uploads/
FILE_UPLOAD_SERVER_ADDRESS=http://localhost:18080

# ---- 日志级别（debug / info / warn / error） ----
LOG_LEVEL=info

# ---- 天气 API（可选） ----
WEATHER_API_ID=
WEATHER_API_KEY=

# ---- AI 模型（可选） ----
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ---- 阿里云 OSS（可选） ----
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=

# ---- 阿里云 SMS（可选） ----
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# ---- JVM ----
JAVA_OPTS=-Xms256m -Xmx512m
